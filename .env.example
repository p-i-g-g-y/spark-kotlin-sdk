# spark-kotlin-sdk — integration-test environment variables
#
# Copy this file to `.env.local` (gitignored) and fill in your funded test
# wallets. NEVER commit a real mnemonic. NEVER ship `.env.local` anywhere.
#
# These are only consumed by the Android instrumented integration tests
# (`./gradlew :lib:connectedAndroidTest`) — unit tests don't need them.
#
# Alternative: put the same keys in `<repo>/local.properties` instead, using
# the `spark.test.*` names shown below. `local.properties` is already
# gitignored and is read by Gradle automatically — preferred for local dev.

# ----------------------------------------------------------------------
# Required for any integration test
# ----------------------------------------------------------------------

# Funded test wallet (≥ 500 sats on mainnet, regtest is fine too).
# Gradle key: spark.test.walletA.mnemonic
SPARK_TEST_WALLET_A_MNEMONIC="word1 word2 word3 ... word12"

# Receiver-side test wallet — does not need to hold any sats.
# Gradle key: spark.test.walletB.mnemonic
SPARK_TEST_WALLET_B_MNEMONIC="word1 word2 word3 ... word12"

# ----------------------------------------------------------------------
# Optional — Lightning-address (LNURL-pay) test path
# ----------------------------------------------------------------------

# Recipient Lightning address used by external-pay tests. Tests that need
# this skip when the value is empty.
# Gradle key: spark.test.lnAddress
SPARK_TEST_LN_ADDRESS=""
